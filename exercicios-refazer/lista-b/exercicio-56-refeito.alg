Algoritmo "exercicio-56-refeito"

Var

n: inteiro
contador: inteiro
soma: inteiro

Inicio
contador <- 0
soma <- 0

Repita
Escreva ("Digite um numero: ")
Leia (n)

  se (n>=1111) entao
  soma <- soma + 0
  senao
  soma <- soma + n
  fimse
  
Ate (n=1111)
Fimenquanto

LimpaTela
Escreval ("TOTAL DA SOMA: ",soma)
Fimalgoritmo