Algoritmo "gerador_aprendendo_portugol"

Var
   msg: caracter
procedimento gerador(txt: caracter)
inicio
  txt <- "Aprendendo Portugol"
  Escreval (txt)
fimprocedimento

Inicio
  Escreval ("+-------========------+")
  gerador()
  Escreval (msg)
  Escreval ("+-------========------+")

Fimalgoritmo