Algoritmo "posicao_da_letra"

Var
frase: caractere

letra: caractere

Inicio
Escreval ("Digite uma frase abaixo: ")
Leia (frase)
Escreval ("Qual letra deseja encontrar? ")
Leia (letra)
Escreval ("A letra ",letra," foi encontrada pela primeira vez na posińŃo ",Pos(letra, frase),".")
Fimalgoritmo