Algoritmo "somatorio"
// 4) Desenvolva um algoritmo que leia dois números inteiros e mostre o somatório entre eles.
Var
  n1, n2, somatorio: inteiro
Inicio
  Escreva ("Digite um número: ")
  Leia (n1)
  Escreva ("Digite um número: ")
  Leia (n2)
  somatorio <- (n1+n2)
  EscrevaL ("A soma entre", n1, " e", n2, " é igual a",somatorio)
Fimalgoritmo