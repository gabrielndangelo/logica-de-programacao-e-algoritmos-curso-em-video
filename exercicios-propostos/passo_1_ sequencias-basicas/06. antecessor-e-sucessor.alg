Algoritmo "numeroesucessor"

Var
numero, antecessor, sucessor: inteiro

Inicio
 Escreva ("Digite um número: ")
 Leia (numero)
 antecessor <- numero - 1
 sucessor <- numero + 1
 EscrevaL ("O antecessor de", numero," é", antecessor)
 EscrevaL ("O sucessor de", numero," é", sucessor)
Fimalgoritmo