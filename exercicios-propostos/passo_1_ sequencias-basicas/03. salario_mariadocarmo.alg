Algoritmo "salario_funcionario_2"
Var
 salario: real
 nome_funcionario: caractere
Inicio
   Escreval ("Escreva o nome do funcionário: ")
   Leia (nome_funcionario)
    salario <- 1850.45
   Escreval ("O funcionário ", nome_funcionario, " tem um salario de ", salario, " em junho.")
Fimalgoritmo