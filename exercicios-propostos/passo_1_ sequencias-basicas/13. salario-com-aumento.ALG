Algoritmo "salario_com_aumento"
// ler o sal·rio de um funcion·rio e acrescentar 15% de aumento
Var
salario, salario_aumento: real
Inicio
  Escreval ("----------------")
  Escreval ("EMPRESA X.Y.Z")
  EscrevaL ("----------------")
  EscrevaL ("Digite o sal·rio do funcion·rio:")
  Leia (salario)
  salario_aumento <- (salario / 100)*15
  EscrevaL ("--------------------")
  EscrevaL ("NOVO SAL¡RIO: ", salario + salario_aumento:2:2)
fimalgoritmo