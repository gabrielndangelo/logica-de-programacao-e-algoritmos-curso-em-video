Algoritmo "fibonacci_dois"

Var

c: inteiro
n1: inteiro
n2: inteiro
n3: inteiro

Inicio
n1 <- 0
n2 <- 1

Para c de 1 ate 10 faca
Escreva (n2)

// n1 é igual a 0 e n2 é igual a 1, portanto
// n3 = n1 + n2 (0+1)

n3 <- n1 + n2

// 0 se torna 1, 1 se torna 2 e assim por diante.
n1 <- n2
n2 <- n3
FimPara
Fimalgoritmo