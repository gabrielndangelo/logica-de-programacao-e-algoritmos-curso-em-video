Algoritmo "contagem_5_em_5"

Var
 numero_pedido, contador, fim: inteiro

Inicio
contador <- 1
Escreval ("DIGITE UM N⁄MERO: ")
Leia (numero_pedido)
fim <- numero_pedido
   Enquanto contador<=fim faca
   Escreval (contador)
   contador <- contador + 1
   fimenquanto
Escreval ("    A C A B O U !    ")
Fimalgoritmo