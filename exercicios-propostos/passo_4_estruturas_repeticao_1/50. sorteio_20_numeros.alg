Algoritmo "sorteio_20_numeros"
Var
numeros, n, por_3: inteiro
Inicio
Enquanto (numeros<=19) faca
numeros <- numeros + 1
aleatorio 1,10
leia (n)
aleatorio off
se (n>5) entao
Escreval ("MAIOR QUE 5")
fimse
por_3 <- n\3
se (n=9) ou (n=6) entao
Escreval ("É DIVISÍVEL POR 3")
fimse
fimenquanto
Fimalgoritmo